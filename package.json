{
  "name": "jp-lms-vibeops-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "web:dev": "npm --workspace @jp-lms-vibeops/web run dev",
    "web:build": "npm --workspace @jp-lms-vibeops/web run build",
    "web:typecheck": "npm --workspace @jp-lms-vibeops/web run typecheck",
    "web:validate": "npm run web:typecheck && npm run web:build"
  },
  "overrides": {
    "postcss": "8.5.10",
    "next": {
      "postcss": "8.5.10"
    }
  }
}
